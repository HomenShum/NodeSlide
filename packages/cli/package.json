{
  "name": "@nodeslide/cli",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "files": ["dist", "README.md"],
  "bin": {
    "nodeslide": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --sourcemap --platform node --external @nodeslide/registry",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nodeslide/registry": "0.2.0"
  }
}
