      "rules": [
        {
          "behavior": "Frame the audience as the main actor and organize the narrative around the change they need rather than around the presenter, company, or product.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "Frame the audience, rather than the speaker, company, or product, as the main actor; focus the message on what the audience needs and the change in what they think, feel, believe, or do.",
              "title": "Center the audience's transformation",
              "url": "https://www.duarte.com/blog/presentation-storytelling-audience-is-hero/"
            }
          ],
          "id": "startup.audience-centered-arc",
          "title": "Center the audience transformation"
        },
        {
          "behavior": "Give each substantive slide one evidence-backed takeaway and split the slide when two independent claims remain.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "Limit a slide to one main idea so the visual supports the spoken message instead of competing with it.",
              "title": "Keep one clear takeaway per slide",
              "url": "https://www.duarte.com/blog/presenting/"
            }
          ],
          "id": "startup.single-takeaway",
          "title": "Keep one takeaway per slide"
        },
        {
          "behavior": "Move from shared current context through credible evidence toward a possible future without copying a proprietary story diagram or pitch-deck sequence.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "Establish a shared current reality, introduce a credible possible future, and keep presentation content aligned to the audience's intended transformation.",
              "title": "Contrast current reality with a possible future",
              "url": "https://www.duarte.com/blog/move-presentation-audience-with-story-techniques-in-presentations/"
            }
          ],
          "id": "startup.current-future-contrast",
          "title": "Contrast current reality with a possible future"
        },
        {
          "behavior": "Use design to carry meaning, remove non-meaningful decoration, and keep the slide only as complex as its message requires.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "Use design to carry meaning, not as decoration; remove superfluous details and keep the slide as simple as the message allows.",
              "title": "Make every visual element earn its place",
              "url": "https://www.duarte.com/blog/presenting/"
            }
          ],
          "id": "startup.purposeful-simplicity",
          "title": "Make each visual element earn its place"
        },
        {
          "behavior": "Reserve open space around the essential message and split cluttered content instead of shrinking it.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "Use open space to direct focus; when a slide feels cluttered, reduce or split its content so the essential message remains clear.",
              "title": "Preserve whitespace for focus",
              "url": "https://www.duarte.com/blog/techniques-for-using-critique-language-for-more-powerful-and-effective-presentations/"
            }
          ],
          "id": "startup.whitespace-for-focus",
          "title": "Preserve whitespace for focus"
        },
        {
          "behavior": "Close with a supplied verb-plus-object ask and add an owner or timing only when the brief provides them.",
          "citations": [
            {
              "license": "No permissive content license identified; citation and idea-level paraphrase only. Do not reproduce source prose, images, diagrams, templates, course materials, trade dress, or marks; no affiliation or endorsement.",
              "supports": "At the end, state clearly what the audience can do to move from the current state toward the possible future, using concrete tasks.",
              "title": "End with a clear next action",
              "url": "https://www.duarte.com/blog/audience-engagement-strategies-presentations/"
            }
          ],
          "id": "startup.decisive-next-action",
