{
  "name": "@nodeslide/convex",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./component": {
      "types": "./dist/component.d.ts",
      "import": "./dist/component.js"
    },
    "./component-schema": {
      "types": "./dist/componentSchema.d.ts",
      "import": "./dist/componentSchema.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:client && npm run build:component",
    "build:client": "tsup src/index.ts src/capabilityHost.ts src/react.tsx src/component.ts src/componentSchema.ts --format esm --dts --clean --sourcemap --external react --external react/jsx-runtime --external convex --external convex/browser --external convex/server --external convex/values --external @nodeslide/backend --external @nodeslide/contracts --external @nodeslide/engine --external @nodeslide/react --external @nodeslide/react-headless",
    "build:component": "tsc -p tsconfig.component.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nodeslide/backend": "0.2.2",
    "@nodeslide/contracts": "0.2.2",
    "@nodeslide/engine": "0.2.2",
    "@nodeslide/react": "0.2.2",
    "@nodeslide/react-headless": "0.2.2"
  },
  "peerDependencies": {
    "convex": ">=1.42 <2",
    "react": ">=18 <20"
  }
}
