{
  "name": "@nodeslide/external-agent",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Offline governed DeckSpec inspection and patching for coding agents and automation.",
  "license": "UNLICENSED",
  "bin": {
    "nodeslide": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --platform node --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@nodeslide/backend": "0.2.2",
    "@nodeslide/contracts": "0.2.2",
    "@nodeslide/engine": "0.2.2",
    "@nodeslide/testing": "0.2.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
