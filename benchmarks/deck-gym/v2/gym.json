{
  "schemaVersion": "nodekit.gym-config/v1",
  "gymVersion": "nodeslide-deck-gym-v2",
  "description": "Paired repeated artifact experiments across model and harness cohorts. Planning a run never promotes or routes it.",
  "expectedMatrixSize": 720,
  "repetitions": 3,
  "tasks": [
    {
      "id": "public-artifact-selection",
      "taskClass": "artifact-selection",
      "curriculumLevel": 1,
      "pool": "public-development",
      "task": "Classify the narrative job and select one dominant artifact without compiling it.",
      "evidence": "Public consented fixture containing two qualitative claims.",
      "reference": "ArtifactSpec comparison selector v1",
      "trainingEligible": true,
      "fixture": {
        "mode": "inline",
        "payload": {
          "schemaVersion": "nodekit.gym-task-fixture/v1",
          "taskId": "public-artifact-selection",
          "taskClass": "artifact-selection",
          "pool": "public-development",
          "brief": "Choose the clearest dominant artifact for a two-option operating-model decision.",
          "evidence": {
            "sources": [
              {
                "id": "public-selection-source",
                "title": "NodeGym synthetic public selection fixture",
                "digest": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
                "claimIds": ["selection-claim-a", "selection-claim-b"],
                "license": "CC0-1.0",
                "consentScope": "training-approved",
                "trainingUseAllowed": true
              }
            ],
            "claims": [
              {
                "id": "selection-claim-a",
                "text": "Option A centralizes governance.",
                "sourceIds": ["public-selection-source"]
              },
              {
                "id": "selection-claim-b",
                "text": "Option B preserves team autonomy.",
                "sourceIds": ["public-selection-source"]
              }
            ]
          },
          "reference": {
            "artifactKind": "comparison",
            "validator": "ArtifactSpec comparison validator v1",
            "semanticAssertions": ["both options represented", "trade-off explicit"]
          },
          "constraints": {
            "requiredTopics": ["governance", "autonomy"],
            "requiredStoryBeats": ["decision", "trade-off"],
            "minimumDistinctVisualKinds": 1
          },
          "repairCase": {
            "sourceSpecDigest": "sha256:1212121212121212121212121212121212121212121212121212121212121212",
            "sourceSpec": { "kind": "comparison", "payload": { "cohorts": [] } },
            "renderIssue": { "code": "comparison_labels_missing", "paths": ["/payload/cohorts"] }
          },
          "governance": {
            "consentScope": "training-approved",
            "trainingEligible": true,
            "retention": "retained",
            "containsPersonalData": false
          }
        }
      }
    },
    {
      "id": "public-dominant-visual",
      "taskClass": "dominant-visual",
      "curriculumLevel": 2,
      "pool": "public-development",
      "task": "Plan one evidence-bound chart and its narrative job from a bounded public fixture.",
      "evidence": "Public consented fixture with one explicit numeric fact and unit.",
      "reference": "ArtifactSpec chart validator v1",
      "trainingEligible": true,
      "fixture": {
        "mode": "inline",
        "payload": {
          "schemaVersion": "nodekit.gym-task-fixture/v1",
          "taskId": "public-dominant-visual",
          "taskClass": "dominant-visual",
          "pool": "public-development",
          "brief": "Show the observed annual recurring revenue result as one legible dominant chart.",
          "evidence": {
            "sources": [
              {
                "id": "public-arr-source",
                "title": "NodeGym synthetic public ARR fixture",
                "digest": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
                "claimIds": ["arr-claim"],
                "license": "CC0-1.0",
                "consentScope": "training-approved",
                "trainingUseAllowed": true
              }
            ],
            "claims": [
              {
                "id": "arr-claim",
                "text": "Annual recurring revenue reached 42 million dollars.",
                "acceptedRenderings": ["ARR reached $42M."],
                "sourceIds": ["public-arr-source"],
                "numericFacts": [{ "id": "arr-value", "value": 42, "unit": "USDm", "tolerance": 0 }]
              }
            ]
          },
          "reference": {
            "artifactKind": "chart",
            "validator": "ArtifactSpec chart validator v1",
            "requiredFactPaths": ["/payload/series/0/values/0"],
            "semanticAssertions": ["unit shown", "axis labeled", "claim bound"]
          },
          "constraints": {
            "requiredTopics": ["arr", "unit"],
            "requiredStoryBeats": ["result", "implication"],
            "minimumDistinctVisualKinds": 1
          },
          "repairCase": {
            "sourceSpecDigest": "sha256:2323232323232323232323232323232323232323232323232323232323232323",
            "sourceSpec": { "kind": "chart", "payload": { "unit": "", "series": [] } },
            "renderIssue": { "code": "chart_unit_missing", "paths": ["/payload/unit"] }
          },
          "governance": {
            "consentScope": "training-approved",
            "trainingEligible": true,
            "retention": "retained",
            "containsPersonalData": false
          }
        }
      }
    },
    {
