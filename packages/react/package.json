{
  "name": "@nodeslide/react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": ["./src/styles.css"],
  "files": ["dist", "src/styles.css", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --external react --external react/jsx-runtime",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nodeslide/backend": "0.1.0",
    "@nodeslide/contracts": "0.1.0",
    "@nodeslide/engine": "0.1.0"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  }
}
