{
  "name": "@nodeslide/react",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --external react --external react/jsx-runtime --external @nodeslide/backend --external @nodeslide/contracts --external @nodeslide/react-headless",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nodeslide/backend": "0.2.2",
    "@nodeslide/contracts": "0.2.2",
    "@nodeslide/react-headless": "0.2.2"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  }
}
