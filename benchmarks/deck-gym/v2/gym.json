      "trainingEligible": true,
      "fixture": {
        "mode": "inline",
        "payload": {
          "schemaVersion": "nodekit.gym-task-fixture/v1",
          "taskId": "public-equation",
          "taskClass": "equation",
          "pool": "public-development",
          "brief": "Evaluate a quality-to-cost ratio from the supplied public values and show the typed equation.",
          "evidence": {
            "sources": [
              {
                "id": "public-equation-source",
                "title": "NodeGym synthetic public equation fixture",
                "digest": "sha256:3333333333333333333333333333333333333333333333333333333333333333",
                "claimIds": ["equation-claim"],
                "license": "CC0-1.0",
                "consentScope": "training-approved",
                "trainingUseAllowed": true
              }
            ],
            "claims": [
              {
                "id": "equation-claim",
                "text": "The quality-to-cost ratio is 2.",
                "sourceIds": ["public-equation-source"],
                "numericFacts": [
                  { "id": "quality-value", "value": 0.8, "unit": "score", "tolerance": 0 },
                  { "id": "cost-value", "value": 0.4, "unit": "index", "tolerance": 0 },
                  { "id": "ratio-value", "value": 2, "unit": "ratio", "tolerance": 0 }
                ]
              }
            ]
          },
          "reference": {
            "artifactKind": "equation",
            "validator": "ArtifactSpec equation validator v1",
            "requiredFactPaths": ["/payload/values/Q", "/payload/values/C", "/payload/result"],
            "semanticAssertions": ["AST evaluates to result", "variables carry units"]
          },
          "constraints": {
            "requiredTopics": ["quality", "cost", "ratio"],
            "requiredStoryBeats": ["inputs", "calculation", "result"],
            "minimumDistinctVisualKinds": 1
          },
          "repairCase": {
            "sourceSpecDigest": "sha256:3434343434343434343434343434343434343434343434343434343434343434",
            "sourceSpec": { "kind": "equation", "payload": { "result": 0 } },
            "renderIssue": { "code": "equation_evaluation_mismatch", "paths": ["/payload/result"] }
          },
          "governance": {
            "consentScope": "training-approved",
            "trainingEligible": true,
            "retention": "retained",
            "containsPersonalData": false
          }
        }
      }
    },
