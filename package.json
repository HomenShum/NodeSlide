{
  "name": "nodeslide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NodeSlide — reviewable deck-as-code. Every AI edit is a scoped, validated, receipted proposal.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "concurrently -n vite,convex -c blue,magenta \"vite\" \"convex dev\"",
    "dev:web": "vite",
    "dev:backend": "convex dev",
    "codegen": "convex codegen",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "ai": "^7.0.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.42.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.12.0",
    "nanoid": "^6.0.0",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "@protobufjs/utf8": "^1.1.2",
    "dompurify": "^3.4.11",
    "protobufjs": "7.6.3",
    "ws": "^8.21.0"
  }
}
